# ShipAny Next — environment variables
#
# Local development:
#   cp .env.example .env.development   # then fill in the values below
#
# Loader priority (scripts/with-env.ts + vite loadEnvFiles):
#   .env.{NODE_ENV}.local > .env.{NODE_ENV} > .env.local > .env
# So in dev, .env.development is picked up by both `pnpm dev` and the db scripts.
#
# Keep this file minimal: provider credentials (payments, OAuth, email,
# storage, AI, analytics) are configured in the admin panel → Settings and
# stored in the database (encrypted when CONFIG_ENCRYPTION_KEY is set).
# Env vars with the matching names still work as fallbacks — database values
# take precedence — but they don't need to live in this template.

# ---------------------------------------------------------------------------
# Required
# ---------------------------------------------------------------------------
VITE_APP_URL=https://hicode.run
VITE_APP_NAME=CodeAgent
DATABASE_PROVIDER=sqlite
DATABASE_URL=file:data/local.db
# Generate with: openssl rand -base64 32
AUTH_SECRET=

# ---------------------------------------------------------------------------
# App (optional — sensible defaults exist in src/config/index.ts)
# ---------------------------------------------------------------------------
VITE_APP_DESCRIPTION=Run Claude Code-like AI coding sessions in secure cloud sandboxes from your browser.
VITE_APP_LOGO=/logo.svg
VITE_DEFAULT_LOCALE=en
# Runtime Worker base URL (spike 06 deployment). Public — browser connects directly.
VITE_RUNTIME_BASE_URL=https://codeagent-spike-integrated-session-mvp.eric-wuyu1352.workers.dev
# Keep this at 1 until the runtime has its own idle reaper / quota manager.
CODE_MAX_ACTIVE_SESSIONS=1

# ---------------------------------------------------------------------------
# Admin settings encryption (recommended)
# ---------------------------------------------------------------------------
# Encrypts secrets saved via admin Settings (AES-256-GCM) in the config table.
# Unset = plaintext storage. Once set, keep it stable — rotating or removing
# it orphans already-encrypted values (they fall back to env values).
# Generate with: openssl rand -base64 32
CONFIG_ENCRYPTION_KEY=

# ---------------------------------------------------------------------------
# Database (advanced / non-sqlite)
# ---------------------------------------------------------------------------
# DATABASE_PROVIDER options: sqlite | postgres | mysql | turso | d1
#   PostgreSQL: set DATABASE_URL to your provider URL, e.g. postgresql://host:5432/dbname
#   MySQL:      set DATABASE_URL to your provider URL, e.g. mysql://host:3306/dbname
#   Turso:      libsql://<db>.turso.io   (also set DATABASE_AUTH_TOKEN below)
# DATABASE_AUTH_TOKEN=                # Turso auth token (required for turso)
# DB_SCHEMA=public                    # Postgres schema
# DB_SINGLETON_ENABLED=false          # reuse a single connection (serverless)
# DB_MAX_CONNECTIONS=1

# ---------------------------------------------------------------------------
# Auth (optional — AUTH_URL defaults to VITE_APP_URL)
# ---------------------------------------------------------------------------
# AUTH_URL=http://localhost:3000
