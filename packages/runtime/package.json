{
  "name": "hicode-runtime",
  "private": true,
  "type": "module",
  "scripts": {
    "check": "tsc --noEmit && PYTHONPYCACHEPREFIX=/tmp/hicode-pycache python3 -m unittest discover -s container -p 'test_*.py'",
    "vendor:fetch": "node scripts/fetch-vendor.mjs",
    "deploy": "wrangler deploy --config wrangler.jsonc",
    "deploy:worker": "wrangler deploy --config wrangler.jsonc --containers-rollout=none",
    "smoke": "node scripts/remote-smoke-test.mjs"
  },
  "dependencies": {
    "@cloudflare/containers": "^0.0.25"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260630.0",
    "typescript": "^5.8.3",
    "wrangler": "^4.23.0"
  }
}
